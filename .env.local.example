# Neon Postgres connection string (from neon.tech dashboard → Connection Details → Pooled connection)
DATABASE_URL=postgres://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# Operator Console access token (generate with: openssl rand -hex 32)
OPERATOR_TOKEN=replace-with-openssl-rand-hex-32

# Anthropic API key (from console.anthropic.com)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Kill Switch: monthly LLM budget limit in USD
MAX_MONTHLY_USD=50
# Set to 'true' to bypass the kill switch (emergency override)
KILL_SWITCH_OVERRIDE=false
