# Neon Postgres connection string (from neon.tech dashboard → Connection Details)
DATABASE_URL=postgres://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# Anthropic Claude API key (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Operator Console access token (generate: openssl rand -hex 32)
OPERATOR_TOKEN=replace-with-openssl-rand-hex-32

# Monthly LLM budget cap in USD (Kill Switch threshold)
MAX_MONTHLY_USD=50

# Set to 'true' to bypass Kill Switch (emergency override)
KILL_SWITCH_OVERRIDE=false

# Optional: Sentry DSN for error tracking (Story 1.9)
# SENTRY_DSN=
